generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MailStatus {
  PENDING
  SENT
  FAILED
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  POOR
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
  CANCELLED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

model Organization {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  timezone       String          @default("Asia/Kolkata")
  currency       String          @default("INR")
  assetTagPrefix String          @default("AF")
  users          User[]
  departments    Department[]
  categories     AssetCategory[]
  assets         Asset[]
  assetTagCounter AssetTagCounter?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Department {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String
  description    String?
  isActive       Boolean        @default(true)
  parentId       String?
  parent         Department?    @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children       Department[]   @relation("DepartmentHierarchy")
  headId         String?        @unique
  head           User?          @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  members        User[]         @relation("DepartmentMembers")
  assets         Asset[]
  allocations    AssetAllocation[]
  transferTargets TransferRequest[]
  bookings       ResourceBooking[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@index([parentId])
}

model AssetCategory {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  isActive         Boolean      @default(true)
  fieldDefinitions String       @default("[]")
  assets           Asset[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
}

model User {
  id                  String               @id @default(cuid())
  organizationId      String
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId        String?
  department          Department?          @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  headedDepartment    Department?          @relation("DepartmentHead")
  name                String
  email               String               @unique
  passwordHash        String
  role                Role                 @default(EMPLOYEE)
  status              UserStatus           @default(ACTIVE)
  avatarColor         String               @default("slate")
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  mailOutbox           MailOutbox[]
  directAllocations    AssetAllocation[]    @relation("AllocationAssignee")
  createdAllocations   AssetAllocation[]    @relation("AllocationCreator")
  closedAllocations    AssetAllocation[]    @relation("AllocationCloser")
  statusChanges        AssetStatusHistory[] @relation("AssetStatusActor")
  requestedTransfers   TransferRequest[]    @relation("TransferRequester")
  targetTransfers      TransferRequest[]    @relation("TransferTargetUser")
  decidedTransfers     TransferRequest[]    @relation("TransferDecider")
  requestedReturns     ReturnRequest[]      @relation("ReturnRequester")
  decidedReturns       ReturnRequest[]      @relation("ReturnDecider")
  bookings              ResourceBooking[]    @relation("BookingCreator")
  requestedMaintenance MaintenanceRequest[] @relation("MaintenanceRequester")
  approvedMaintenance  MaintenanceRequest[] @relation("MaintenanceApprover")
  technicianWork       MaintenanceRequest[] @relation("MaintenanceTechnician")
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([organizationId, role, status])
  @@index([departmentId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model MailOutbox {
  id        String     @id @default(cuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  recipient String
  subject   String
  body      String
  status    MailStatus @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([recipient, createdAt])
  @@index([status, createdAt])
}

model AssetTagCounter {
  organizationId String       @id
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  value          Int          @default(0)
  updatedAt      DateTime     @updatedAt
}

model Asset {
  id                String               @id @default(cuid())
  organizationId    String
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categoryId        String
  category          AssetCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  departmentId      String?
  department        Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assetTag          String               @unique
  qrValue           String               @unique
  name              String
  serialNumber      String?              @unique
  description       String?
  acquisitionDate   DateTime?
  acquisitionCost   Decimal?
  condition         AssetCondition       @default(GOOD)
  location          String
  status            AssetStatus          @default(AVAILABLE)
  isBookable        Boolean              @default(false)
  customValues      String               @default("{}")
  nextMaintenanceAt DateTime?
  retirementDate    DateTime?
  statusHistory     AssetStatusHistory[]
  allocations       AssetAllocation[]
  transferRequests  TransferRequest[]
  bookings          ResourceBooking[]
  maintenanceRequests MaintenanceRequest[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([organizationId, status])
  @@index([categoryId, status])
  @@index([departmentId])
  @@index([location])
  @@index([name])
}

model AssetStatusHistory {
  id         String       @id @default(cuid())
  assetId    String
  asset      Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromStatus AssetStatus?
  toStatus   AssetStatus
  reason     String
  actorId    String?
  actor      User?        @relation("AssetStatusActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime     @default(now())

  @@index([assetId, createdAt])
  @@index([actorId])
}

model AssetAllocation {
  id                   String            @id @default(cuid())
  assetId              String
  asset                Asset             @relation(fields: [assetId], references: [id], onDelete: Restrict)
  assigneeUserId       String?
  assigneeUser         User?             @relation("AllocationAssignee", fields: [assigneeUserId], references: [id], onDelete: Restrict)
  assigneeDepartmentId String?
  assigneeDepartment   Department?       @relation(fields: [assigneeDepartmentId], references: [id], onDelete: Restrict)
  expectedReturnAt     DateTime?
  allocatedAt          DateTime          @default(now())
  returnedAt           DateTime?
  checkoutCondition    AssetCondition
  checkoutNotes        String?
  returnCondition      AssetCondition?
  returnNotes          String?
  status               AllocationStatus  @default(ACTIVE)
  createdById          String
  createdBy            User              @relation("AllocationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  closedById           String?
  closedBy             User?             @relation("AllocationCloser", fields: [closedById], references: [id], onDelete: SetNull)
  transferRequests     TransferRequest[]
  returnRequests       ReturnRequest[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([assetId, status])
  @@index([assigneeUserId, status])
  @@index([assigneeDepartmentId, status])
  @@index([expectedReturnAt, status])
}

model TransferRequest {
  id                 String         @id @default(cuid())
  assetId            String
  asset              Asset          @relation(fields: [assetId], references: [id], onDelete: Restrict)
  allocationId       String
  allocation         AssetAllocation @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  requestedById      String
  requestedBy        User           @relation("TransferRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  targetUserId       String?
  targetUser         User?          @relation("TransferTargetUser", fields: [targetUserId], references: [id], onDelete: Restrict)
  targetDepartmentId String?
  targetDepartment   Department?    @relation(fields: [targetDepartmentId], references: [id], onDelete: Restrict)
  reason             String
  status             TransferStatus @default(REQUESTED)
  decidedById        String?
  decidedBy          User?          @relation("TransferDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  decisionNotes      String?
  decidedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([assetId, status])
  @@index([allocationId, status])
  @@index([requestedById, status])
}

model ReturnRequest {
  id              String         @id @default(cuid())
  allocationId    String
  allocation      AssetAllocation @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  requestedById   String
  requestedBy     User           @relation("ReturnRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  condition       AssetCondition
  checkInNotes    String
  status          ReturnStatus   @default(REQUESTED)
  decidedById     String?
  decidedBy       User?          @relation("ReturnDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  decisionNotes   String?
  decidedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([allocationId, status])
  @@index([requestedById, status])
}

model ResourceBooking {
  id                      String        @id @default(cuid())
  assetId                 String
  asset                   Asset         @relation(fields: [assetId], references: [id], onDelete: Restrict)
  bookedById              String
  bookedBy                User          @relation("BookingCreator", fields: [bookedById], references: [id], onDelete: Restrict)
  onBehalfOfDepartmentId  String?
  onBehalfOfDepartment    Department?   @relation(fields: [onBehalfOfDepartmentId], references: [id], onDelete: Restrict)
  purpose                 String
  startAt                 DateTime
  endAt                   DateTime
  status                  BookingStatus @default(UPCOMING)
  reminderSentAt          DateTime?
  cancelledAt             DateTime?
  cancellationReason      String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([assetId, startAt, endAt, status])
  @@index([bookedById, startAt])
  @@index([onBehalfOfDepartmentId, startAt])
  @@index([status, startAt])
}

model MaintenanceRequest {
  id                  String              @id @default(cuid())
  assetId             String
  asset               Asset               @relation(fields: [assetId], references: [id], onDelete: Restrict)
  requestedById       String
  requestedBy         User                @relation("MaintenanceRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  issue               String
  priority            MaintenancePriority
  status              MaintenanceStatus   @default(PENDING)
  previousAssetStatus AssetStatus?
  approvedById        String?
  approvedBy          User?               @relation("MaintenanceApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt          DateTime?
  rejectedAt          DateTime?
  rejectionReason     String?
  technicianId        String?
  technician          User?               @relation("MaintenanceTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  assignedAt          DateTime?
  scheduledFor        DateTime?
  dueAt               DateTime?
  startedAt           DateTime?
  resolvedAt          DateTime?
  resolution          String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([assetId, status])
  @@index([requestedById, status])
  @@index([technicianId, status])
  @@index([scheduledFor, status])
  @@index([dueAt, status])
}
